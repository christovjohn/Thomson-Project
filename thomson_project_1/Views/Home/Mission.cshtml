
@{
    ViewData["Title"] = "Mission";
}
@section Styles {
    <link rel="stylesheet" href="@Url.Content("~/css/contactus.css")" />
}
@{
    ViewData["Title"] = "Our Mission";
    Layout = "~/Views/Shared/_Layout.cshtml";
}

@section Styles {
    <style>
        /* Hero section */
        .mission-hero {
            background: url('/images/solar-hero.jpg') center center/cover no-repeat;
            color: white;
            text-align: center;
            padding: 120px 20px;
            position: relative;
        }

            .mission-hero::after {
                content: "";
                position: absolute;
                top: 0;
                left: 0;
                right: 0;
                bottom: 0;
                background: rgba(0, 0, 0, 0.4);
            }

            .mission-hero h1, .mission-hero p {
                position: relative;
                z-index: 1;
            }

        /* Core values section */
        .core-values i {
            font-size: 40px;
            color: #f39c12;
            margin-bottom: 15px;
        }

        .core-values h5 {
            font-weight: 600;
        }

        /* Timeline */
        .timeline {
            border-left: 3px solid #f39c12;
            margin-left: 20px;
            padding-left: 20px;
        }

        .timeline-item {
            margin-bottom: 30px;
        }

            .timeline-item h6 {
                color: #f39c12;
                font-weight: bold;
            }
    </style>
}

<!-- Hero Section -->
<section class="mission-hero">
    <h1>Our Mission</h1>
    <p>Empowering Kottayam with sustainable and affordable solar energy solutions</p>
</section>

<div class="container my-5">

    <!-- Mission Statement -->
    <div class="row text-center mb-5">
        <div class="col">
            <h2>What Drives Us</h2>
            <p class="lead">
                At <strong>Thomson Solar</strong>, we are committed to helping homes and businesses
                reduce electricity costs, embrace green energy, and create a brighter future.
            </p>
        </div>
    </div>

    <!-- Core Values -->
    <div class="row text-center core-values mb-5">
        <div class="col-md-3 col-6 mb-4">
            <i class="fa-solid fa-seedling"></i>
            <h5>Sustainability</h5>
            <p>We promote eco-friendly solar solutions for a cleaner planet.</p>
        </div>
        <div class="col-md-3 col-6 mb-4">
            <i class="fa-solid fa-users"></i>
            <h5>Customer Focus</h5>
            <p>Every project is tailored to your unique energy needs.</p>
        </div>
        <div class="col-md-3 col-6 mb-4">
            <i class="fa-solid fa-lightbulb"></i>
            <h5>Innovation</h5>
            <p>Bringing cutting-edge solar technologies to your doorstep.</p>
        </div>
        <div class="col-md-3 col-6 mb-4">
            <i class="fa-solid fa-shield-check"></i>
            <h5>Trust & Quality</h5>
            <p>Reliable services backed by years of experience.</p>
        </div>
    </div>

    <!-- Timeline -->
    <div class="row mb-5">
        <div class="col-md-8 mx-auto">
            <h3 class="text-center mb-4">Our Journey</h3>
            <div class="timeline">
                <div class="timeline-item">
                    <h6>2010</h6>
                    <p>Started as Thomson Computers, serving Kottayam with IT solutions.</p>
                </div>
                <div class="timeline-item">
                    <h6>2020</h6>
                    <p>Expanded into solar panel solutions for homes and businesses.</p>
                </div>
                <div class="timeline-item">
                    <h6>Today</h6>
                    <p>Providing sustainable, affordable, and trusted solar services in Kerala.</p>
                </div>
            </div>
        </div>
    </div>

    <!-- Call to Action -->
    <div class="row text-center my-5">
        <div class="col">
            <h2>Be Part of a Greener Future</h2>
            <p class="lead">Reduce your electricity costs and support a sustainable tomorrow.</p>
            <a href="@Url.Action("ContactUs", "Home")" class="btn btn-success btn-lg">Contact Us Today</a>
        </div>
    </div>
</div>


