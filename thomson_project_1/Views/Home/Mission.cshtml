
@{
    ViewData["Title"] = "Mission";
}
@section Styles {
    
    <link href="~/css/mission.css" rel="stylesheet" />
}
<link href="https://unpkg.com/aos@2.3.1/dist/aos.css" rel="stylesheet">
<script src="https://unpkg.com/aos@2.3.1/dist/aos.js"></script>

@section Scripts{
    <script>
    AOS.init();
</script>
}



<!-- Hero Section -->
<section class="mission-hero">
    <div class="mission-overlay">
        <h1>Our Mission</h1>
        <p>Empowering Kottayam with sustainable and affordable solar energy solutions</p>
    </div>
</section>


<div class="container my-5">

    <!-- Mission Statement -->
    <div class="row text-center mb-5">
        <div class="col">
            <h2 class="what-drive-us">What Drives Us</h2>
            <p class="lead">
                At <strong>Thomson Solar</strong>, we are committed to helping homes and businesses
                reduce electricity costs, embrace green energy, and create a brighter future.
            </p>
        </div>
    </div>

    <!-- Core Values -->
    <div class="row text-center core-values mb-5">
        <div class="col-md-3 col-6 mb-4">
            <i class="fa-solid fa-seedling"></i>
            <h5>Sustainability</h5>
            <p class="lead">We promote eco-friendly solar solutions for a cleaner planet.</p>
        </div>
        <div class="col-md-3 col-6 mb-4">
            <i class="fa-solid fa-users"></i>
            <h5>Customer Focus</h5>
            <p class="lead">Every project is tailored to your unique energy needs.</p>
        </div>
        <div class="col-md-3 col-6 mb-4">
            <i class="fa-solid fa-lightbulb"></i>
            <h5>Innovation</h5>
            <p class="lead">Bringing cutting-edge solar technologies to your doorstep.</p>
        </div>
        <div class="col-md-3 col-6 mb-4">
            <i class="fa-solid fa-medal"></i>
            <h5>Trust & Quality</h5>
            <p class="lead">Reliable services backed by years of experience.</p>
        </div>
    </div>

    <!-- Timeline -->
    <div class="row mb-5">
        <div class="col-md-8 mx-auto">
            <h3 class="our-journey mb-4">Our Journey</h3>
            <div class="timeline">
                <div class="timeline-item">
                    <h6>2010</h6>
                    <p class="lead">Started as Thomson Computers, serving Kottayam with IT solutions.</p>
                </div>
                <div class="timeline-item">
                    <h6>2020</h6>
                    <p class="lead">Expanded into solar panel solutions for homes and businesses.</p>
                </div>
                <div class="timeline-item">
                    <h6>Today</h6>
                    <p class="lead">Providing sustainable, affordable, and trusted solar services in Kerala.</p>
                </div>
            </div>
        </div>
    </div>

    <!-- Call to Action -->
    <div class="row text-center my-5">
        <div class="col">
            <h2 class="green-future-text">Be Part of a Greener Future</h2><img src="~/images/grey_arrow_loop_02.svg" width="150px" class="green-future" />
            <p class="lead">Reduce your electricity costs and support a sustainable tomorrow.</p>
            <a href="@Url.Action("ContactUs", "Home")" class="btn-contact" data-aos="fade-up" data-aos-duration="1000">Contact Us Today</a>
        </div>
    </div>
</div>


