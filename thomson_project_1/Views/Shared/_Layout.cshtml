<!DOCTYPE html>
<html lang="en">
<head>
    <meta charset="utf-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1.0" />
    <title>@ViewData["Title"] - thomson_project_1</title>

    <link rel="stylesheet" href="~/css/site.css" asp-append-version="true" />
    <link rel="stylesheet" href="~/thomson_project_1.styles.css" asp-append-version="true" />
    

    <link href="https://cdn.jsdelivr.net/npm/bootstrap@5.3.3/dist/css/bootstrap.min.css" rel="stylesheet"
          integrity="sha384-QWTKZyjpPEjISv5WaRU9OFeRpok6YctnYmDr5pNlyT2bRjXh0JMhjY6hW+ALEwIH" crossorigin="anonymous">
    
    <script src="https://kit.fontawesome.com/1266619c4c.js" crossorigin="anonymous"></script>
  
    @RenderSection("Styles", required: false)
    @section Scripts {
        @await Html.PartialAsync("_ValidationScriptsPartial")
    }
    
</head>
<body>
    <div class="sticky_head">

    
        
    <div class="head_strip">
        <div class="container">
            <div class="row">
                <div class="col-sm-9 col-md-4 col-xl-4 col-lg-4 d-flex align-items-center head_strip_content">
                    <div class="head_strip_icon">
                        <i class="fa-solid fa-phone-volume"></i>

                    </div>
                    <div class="head_strip_text">
                        <h6 class="head_strip_value">Contact Us: 0481-2565628, +91 9447567532</h6>

                    </div>



                </div>
                <div class="col-sm-4 col-md-4 col-xl-4 col-lg-4 d-flex align-items-center head_strip_content">
                    <div class="head_strip_icon">
                        <i class="fa-solid fa-location-dot"></i>

                    </div>
                    <div class="head_strip_text">
                        <h6 class="head_strip_value">Kottayam</h6>
                    </div>



                </div>
                <div class="col-sm-4 col-md-4 col-xl-4 col-lg-4 d-flex align-items-center head_strip_content">
                    <div class="head_strip_icon">
                        <i class="fa-solid fa-envelope"></i>
                    </div>

                    <div class="head_strip_text">
                        <h6 class="head_strip_value">thomsonkottayam@gmail.com</h6>
                    </div>


                </div>

            </div>

        </div>

    </div>

        
        <nav class="navbar navbar-expand-lg bg-body-tertiary">
            <div class="container-fluid">
                <a class="navbar-brand" href="#">Thomson Solar</a>
                <button class="navbar-toggler" type="button" data-bs-toggle="collapse" data-bs-target="#navbarNav"
                        aria-controls="navbarNav" aria-expanded="false" aria-label="Toggle navigation">
                    <span class="navbar-toggler-icon"></span>
                </button>
                <div class="collapse navbar-collapse justify-content-center" id="navbarNav">
                    <ul class="navbar-nav">
                        <li class="nav-item">
                        <a class="nav-link active" aria-current="page" asp-controller="Home" asp-action="Index">Home</a>
                        </li>
                        <li class="nav-item">
                        <a class="nav-link" asp-controller="Home" asp-action="Gallery">Our Project</a>
                        </li>
                        <li class="nav-item">
                        <a class="nav-link" asp-controller="Home" asp-action="Mission">Mission</a>
                        </li>
                        <li class="nav-item">
                        <a class="nav-link" asp-controller="Home" asp-action="ContactUs">Contact Us</a>
                        </li>
                    </ul>
                </div>
            </div>
        </nav>
    </div>
    
    
        <main role="main" class="pb-3">
            @RenderBody()
        </main>
    <a href="https://wa.me/+918281014587" class="whatsapp-float" target="_blank" aria-label="Chat with us on WhatsApp">
        <img src="https://img.icons8.com/color/96/000000/whatsapp--v1.png" />

    </a>

   

    <div class="footer">
        <div class="container-fluid">
            <h5 class="footer_title">Thomson Solar</h5>
            <div class="container">
                <div class="row">
                    <div class="col">
                        <div class="footer_About_Us">
                            <h5> About Us</h5>
                            <p class="About_Us">
                                Thomson Solar is a leading global solar innovative and Solution
                                selling solar systems company .
                                Thomson Solar is ardently involved as a prominent Retailing of Solar Water Heater,
                                Solar Panel, Solar Battery etc. The company works to give the alternate energy market,
                                now
                                in its
                                infancy, a trusted and reliable source for energy solutions. It encourages customers to
                                look
                                beyond
                                the conventional and at the same time, make their contribution to preserving the planet.
                            </p>

                        </div>



                    </div>
                    <div class="col">
                        <h5 class="About_Us">Quick links</h5>
                        <a href="./index.html">Home</a> <br>
                        <a href="./gallary.html">Our Projects</a> <br>
                        <a href="./mission.html">Mission</a> <br>
                        <a href="./contactus.html">Contact Us</a> <br>

                    </div>
                    <div class="col">
                        <h5 class="About_Us">Contact Info</h5>
                        <h6 class="About_Us">kottayam</h6>
                        <h6 class="About_Us">thomsonkottayam@gmail.com</h6>
                        <h6 class="About_Us">0481-2565628, +91 9447567532</h6>
                    </div>
                    <div class="col">
                        <h5 class="About_Us">Follow Us On Social Media</h5>
                    </div>

                </div>



            </div>

        </div>

    </div>
    <script src="https://cdn.jsdelivr.net/npm/bootstrap@5.3.3/dist/js/bootstrap.bundle.min.js"
            integrity="sha384-YvpcrYf0tY3lHB60NNkmXc5s9fDVZLESaAA55NDzOxhy9GkcIdslK1eN7N6jIeHz"
            crossorigin="anonymous"></script>
    <script src="https://cdn.jsdelivr.net/npm/@@popperjs/core@2.11.8/dist/umd/popper.min.js"
            integrity="sha384-I7E8VVD/ismYTF4hNIPjVp/Zjvgyol6VFvRkX/vR+Vc4jQkC+hVqc2pM8ODewa9r"
            crossorigin="anonymous"></script>
    
    @* <script src="~/lib/jquery/dist/jquery.min.js"></script>
    @* <script src="~/lib/bootstrap/dist/js/bootstrap.bundle.min.js"></script> *@
    <script src="~/js/site.js" asp-append-version="true"></script>
    @await RenderSectionAsync("Scripts", required: false)
</body>
</html>
