<!DOCTYPE html>
<html lang="en">
<head>
    <meta charset="utf-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1.0" />
    <title>@ViewData["Title"] - thomson_project_1</title>

    <link rel="stylesheet" href="~/css/site.css" asp-append-version="true" />
    <link rel="stylesheet" href="~/thomson_project_1.styles.css" asp-append-version="true" />
    <link rel="stylesheet" href="https://cdn.jsdelivr.net/npm/bootstrap-icons@1.13.1/font/bootstrap-icons.min.css">

    <link href="https://cdn.jsdelivr.net/npm/bootstrap@5.3.3/dist/css/bootstrap.min.css" rel="stylesheet"
          integrity="sha384-QWTKZyjpPEjISv5WaRU9OFeRpok6YctnYmDr5pNlyT2bRjXh0JMhjY6hW+ALEwIH" crossorigin="anonymous">
    
    <script src="https://kit.fontawesome.com/1266619c4c.js" crossorigin="anonymous"></script>
  
    @RenderSection("Styles", required: false)
    @section Scripts {
        @await Html.PartialAsync("_ValidationScriptsPartial")
    }
    
</head>
<body>
    @* <div class="page-wrapper d-flex flex-column min-vh-100"> *@
    <div class="sticky_head">

    
        
    <div class="head_strip">
        <div class="container">
            <div class="row">
                <div class="col-sm-9 col-md-4 col-xl-4 col-lg-4 d-flex align-items-center head_strip_content">
                    <div class="head_strip_icon">
                        <i class="fa-solid fa-phone-volume"></i>

                    </div>
                    <div class="head_strip_text">
                        <h6 class="head_strip_value">Contact Us: 0481-XXXXXXX, +91 XXXXXXXXX</h6>

                    </div>



                </div>
                <div class="col-sm-4 col-md-4 col-xl-4 col-lg-4 d-flex align-items-center head_strip_content">
                    <div class="head_strip_icon">
                        <i class="fa-solid fa-location-dot"></i>

                    </div>
                    <div class="head_strip_text">
                        <h6 class="head_strip_value">Kottayam</h6>
                    </div>



                </div>
                <div class="col-sm-4 col-md-4 col-xl-4 col-lg-4 d-flex align-items-center head_strip_content">
                    <div class="head_strip_icon">
                        <i class="fa-solid fa-envelope"></i>
                    </div>

                    <div class="head_strip_text">
                        <h6 class="head_strip_value">thomsonkottayam@gmail.com</h6>
                    </div>


                </div>

            </div>

        </div>

    </div>

        
        <nav class="navbar navbar-expand-lg bg-body-tertiary">
            <div class="container-fluid">
                <a class="navbar-brand" href="#">Thomson Solar</a>
                <button class="navbar-toggler" type="button" data-bs-toggle="collapse" data-bs-target="#navbarNav"
                        aria-controls="navbarNav" aria-expanded="false" aria-label="Toggle navigation">
                    <span class="navbar-toggler-icon"></span>
                </button>
                <div class="collapse navbar-collapse justify-content-center" id="navbarNav">
                    <ul class="navbar-nav">
                        <li class="nav-item">
                        <a class="nav-link active" aria-current="page" asp-controller="Home" asp-action="Index">Home</a>
                        </li>
                        <li class="nav-item">
                        <a class="nav-link" asp-controller="Home" asp-action="Gallery">Our Project</a>
                        </li>
                        <li class="nav-item">
                        <a class="nav-link" asp-controller="Home" asp-action="Mission">Mission</a>
                        </li>
                        <li class="nav-item">
                        <a class="nav-link" asp-controller="Home" asp-action="ContactUs">Contact Us</a>
                        </li>
                    </ul>
                </div>
            </div>
        </nav>
    </div>
    
    
    
        <main role="main" class="pb-3">
            @RenderBody()
        </main>
    <a href="https://wa.me/" class="whatsapp-float" target="_blank" aria-label="Chat with us on WhatsApp">
        <img src="https://img.icons8.com/color/96/000000/whatsapp--v1.png" />

    </a>
        <footer class="bg-dark text-light pt-5 pb-4">
            <div class="container text-md-left">
                <div class="row text-md-left">

                    <!-- About -->
                    <div class="col-md-4 col-lg-4 col-xl-4 mx-auto mb-4">
                        <h6 class="text-uppercase fw-bold mb-4">About Us</h6>
                        <p>
                            Providing quality solar solutions with trusted service and customer satisfaction.
                            We specialize in energy-efficient solar systems tailored to your needs.
                            Our team ensures reliable installation and long-term maintenance support.
                            Join us in building a greener, sustainable future with clean energy.
                        </p>
                    </div>

                    <!-- Quick Links -->
                    <div class="col-md-2 col-lg-2 col-xl-2 mx-auto mb-4">
                        <h6 class="text-uppercase fw-bold mb-4">Quick Links</h6>
                        <ul class="list-unstyled">
                            <li><a asp-controller="Home" asp-action="Index" class="text-light text-decoration-none">Home</a></li>
                            <li><a asp-controller="Home" asp-action="Gallery" class="text-light text-decoration-none">Our Project</a></li>
                            <li><a asp-controller="Home" asp-action="Mission" class="text-light text-decoration-none">Mission</a></li>
                            <li><a asp-controller="Home" asp-action="ContactUs" class="text-light text-decoration-none">Contact Us</a></li>
                        </ul>
                    </div>

                    <!-- Contact -->
                    <div class="col-md-3 col-lg-3 col-xl-3 mx-auto mb-4">
                        <h6 class="text-uppercase fw-bold mb-4">Contact</h6>
                        <p><i class="bi bi-geo-alt-fill me-2"></i>Kottayam, Kerala</p>
                        <p><i class="bi bi-envelope-fill me-2"></i>thomsonkottayam@gmail.com</p>
                        <p><i class="bi bi-phone-fill me-2"></i>0481-2565628, +91 9447567532</p>
                    </div>

                    <!-- Social -->
                    <div class="col-md-3 col-lg-3 col-xl-3 mx-auto mb-4">
                        <h6 class="text-uppercase fw-bold mb-4">Follow Us</h6>
                        <a href="#" class="text-light me-3"><i class="bi bi-facebook"></i></a>
                        <a href="#" class="text-light me-3"><i class="bi bi-twitter"></i></a>
                        <a href="#" class="text-light me-3"><i class="bi bi-instagram"></i></a>
                        <a href="#" class="text-light"><i class="bi bi-linkedin"></i></a>
                    </div>
                </div>
            </div>

            <!-- Bottom bar -->
            <div class="text-center p-3 border-top border-secondary mt-3">
                © 2025 cvj creation | All Rights Reserved
            </div>
        </footer>


   

    
    <script src="https://cdn.jsdelivr.net/npm/bootstrap@5.3.3/dist/js/bootstrap.bundle.min.js"
            integrity="sha384-YvpcrYf0tY3lHB60NNkmXc5s9fDVZLESaAA55NDzOxhy9GkcIdslK1eN7N6jIeHz"
            crossorigin="anonymous"></script>
    <script src="https://cdn.jsdelivr.net/npm/@@popperjs/core@2.11.8/dist/umd/popper.min.js"
            integrity="sha384-I7E8VVD/ismYTF4hNIPjVp/Zjvgyol6VFvRkX/vR+Vc4jQkC+hVqc2pM8ODewa9r"
            crossorigin="anonymous"></script>
    
    @* <script src="~/lib/jquery/dist/jquery.min.js"></script>
    @* <script src="~/lib/bootstrap/dist/js/bootstrap.bundle.min.js"></script> *@
    <script src="~/js/site.js" asp-append-version="true"></script>
    @await RenderSectionAsync("Scripts", required: false)
</body>
</html>
